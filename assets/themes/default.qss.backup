/* ===== OPTIPLAYER DEFAULT THEME ===== */
/* Style moderne pour OptiPlayer */

QMainWindow {
    background-color: #1e1e2f;
    color: #ffffff;
    font-family: 'Segoe UI', sans-serif;
}

/* Barre de titre */
QMenuBar {
    background-color: #2d2d3a;
    color: white;
    border-bottom: 1px solid #3d3d4a;
}

QMenuBar::item {
    padding: 5px 10px;
    background: transparent;
}

QMenuBar::item:selected {
    background-color: #3d3d4a;
    border-radius: 3px;
}

/* Boutons de contrôle */
QPushButton {
    background-color: #3d3d4a;
    border: none;
    border-radius: 4px;
    color: white;
    padding: 8px 15px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #5d5d6a;
}

QPushButton:pressed {
    background-color: #2d2d3a;
}

/* Bouton spécial (Magic Sync) */
QPushButton#magicSyncButton {
    background-color: #ff6b6b;
    color: white;
    font-weight: bold;
}

QPushButton#magicSyncButton:hover {
    background-color: #ff5252;
}

/* Slider de progression */
QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #3d3d4a;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #ff6b6b;
    width: 18px;
    margin: -6px 0;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background: #ff5252;
    width: 20px;
}

/* Slider de volume */
QSlider::groove:horizontal#volumeSlider {
    background: #2d2d3a;
    height: 4px;
}

QSlider::handle:horizontal#volumeSlider {
    background: #4a90e2;
    width: 12px;
    border-radius: 6px;
}

/* Labels */
QLabel {
    color: #cccccc;
}

QLabel#timeLabel {
    color: #ff6b6b;
    font-weight: bold;
}

/* Liste de lecture */
QListWidget {
    background-color: #2d2d3a;
    border: 1px solid #3d3d4a;
    border-radius: 5px;
    color: white;
    padding: 5px;
}

QListWidget::item {
    padding: 5px;
    border-radius: 3px;
}

QListWidget::item:selected {
    background-color: #4a4a5a;
}

QListWidget::item:hover {
    background-color: #3d3d4a;
}

/* Scrollbar */
QScrollBar:vertical {
    background: #2d2d3a;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #5d5d6a;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #7d7d8a;
}

/* Tooltips */
QToolTip {
    background-color: #2d2d3a;
    color: white;
    border: 1px solid #ff6b6b;
    border-radius: 3px;
    padding: 5px;
}
